# package-import-method=copy: pnpm defaults to hardlinking packages from its
# global content-addressable store into node_modules on Windows. Seen live
# on this machine: `next` (thousands of files, the largest dep in this repo)
# intermittently ends up with most of its dist/ missing between two otherwise
# identical `pnpm --filter @netryx/web build` runs, breaking `next build`
# with "Cannot find module './impl'" — consistent with hitting NTFS's
# per-file hardlink cap when the same store entry is shared across many
# projects on this drive. Copying instead of hardlinking is slower but
# makes node_modules fully self-contained and immune to this.
package-import-method=copy
