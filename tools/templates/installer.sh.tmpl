#!/usr/bin/env bash
# tools/templates/installer.sh.tmpl
# Self-extracting Lumi installer for Linux, generated by tools/build.py's
# build_installer_sh(): this text is filled (__LUMI_VERSION__) and written
# out, then a "__ARCHIVE_BELOW__" marker line and a tar.gz of the staged
# bundle are appended as raw bytes — no external tool (no makeself) needed,
# just tar/gzip. Mirrors tools/templates/installer.iss (the Windows/Inno
# Setup equivalent) step for step: check prerequisites, copy files, seed
# .env, start Postgres, install db's tiny dependency set, offer to launch.
set -euo pipefail

APP_NAME="Lumi"
APP_VERSION="__LUMI_VERSION__"
INSTALL_DIR="${LUMI_INSTALL_DIR:-${1:-$HOME/.local/share/Lumi}}"

echo "Instalando ${APP_NAME} ${APP_VERSION} en ${INSTALL_DIR}"

check_tool() { command -v "$1" >/dev/null 2>&1; }

NODE_OK=0; PNPM_OK=0; DOCKER_OK=0
check_tool node && NODE_OK=1
check_tool pnpm && PNPM_OK=1
check_tool docker && DOCKER_OK=1

if [ "$NODE_OK" -ne 1 ] || [ "$PNPM_OK" -ne 1 ]; then
  echo "ERROR: este instalador necesita Node.js y pnpm en el PATH antes de continuar." >&2
  echo "Instálalos y vuelve a ejecutar este instalador." >&2
  exit 1
fi

if [ "$DOCKER_OK" -ne 1 ]; then
  echo "No se encontró Docker, la forma más sencilla de tener Postgres + pgvector + PostGIS (la base de datos de Lumi)."
  read -r -p "¿Continuar sin Docker? Podrás configurar Postgres manualmente después (.env). [y/N] " reply
  case "$reply" in
    [yY]*) ;;
    *) echo "Instalación cancelada."; exit 1 ;;
  esac
fi

mkdir -p "$INSTALL_DIR"

# Self-extraction: read our own script file back off disk, find the line
# right after the "__ARCHIVE_BELOW__" marker build.py appended, and stream
# everything from there (the tar.gz payload) straight into tar. Standard
# self-extracting-script technique — tail doesn't care that what follows
# isn't text.
ARCHIVE_LINE=$(awk '/^__ARCHIVE_BELOW__$/ {print NR + 1; exit}' "$0")
tail -n +"$ARCHIVE_LINE" "$0" | tar xzf - -C "$INSTALL_DIR"

if [ ! -f "$INSTALL_DIR/.env" ] && [ -f "$INSTALL_DIR/.env.example" ]; then
  cp "$INSTALL_DIR/.env.example" "$INSTALL_DIR/.env"
fi

if [ "$DOCKER_OK" -eq 1 ]; then
  (cd "$INSTALL_DIR" && docker compose up -d --build db)
fi

# apps/web and apps/worker ship pre-built (tools/build.py's next build
# --standalone + esbuild bundle) — only db/'s own small migration-runner
# dependency set (node-pg-migrate, pg, cross-env) still needs installing.
(cd "$INSTALL_DIR" && pnpm install --filter @netryx/db...)

BIN_DIR="$HOME/.local/bin"
mkdir -p "$BIN_DIR"
ln -sf "$INSTALL_DIR/lumi" "$BIN_DIR/lumi"

APPS_DIR="$HOME/.local/share/applications"
mkdir -p "$APPS_DIR"
cat > "$APPS_DIR/lumi.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=${APP_NAME}
Comment=Lumi - busqueda geoespacial
Exec=${INSTALL_DIR}/lumi
Terminal=true
Categories=Utility;
EOF

echo ""
echo "${APP_NAME} se ha instalado en ${INSTALL_DIR} (acceso directo: ~/.local/bin/lumi, y en el menu de aplicaciones)."
echo "Al iniciarlo por primera vez se abrira tu navegador en http://localhost:3000"
echo "La primera vez te llevara automaticamente al asistente de instalacion (/setup), que instala"
echo "los modelos y termina comprobando que el servicio de inferencia y el worker estan realmente arrancados."
echo ""
read -r -p "¿Ejecutar ${APP_NAME} ahora? [Y/n] " run_now
case "$run_now" in
  [nN]*) ;;
  *) exec "$INSTALL_DIR/lumi" ;;
esac

exit 0
